# Generic Local Agent Toolkit Environment Configuration
# Copy this file to .env and fill in your values

# LLM Configuration
# Core API Key for the provider (OpenAI, Gemini, Vertex, Groq, etc)
API_KEY=your_api_key_here

# Base URL for the OpenAI compatible endpoint
API_BASE_URL=https://api.openai.com/v1

# The model name to use for generating text
MODEL=gpt-4o

# Tool and Processing Configuration
# Maximum iterations for tool calls to prevent infinite loops
MAX_ITERATIONS=25

# Logging Configuration (optional)
LOG_LEVEL=INFO
LOG_FILE=agent.log